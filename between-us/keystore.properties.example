# Rename to keystore.properties and fill in YOUR values for production.
# Generate your own key:
#   keytool -genkeypair -v -keystore my-upload.keystore -alias my-alias \
#     -keyalg RSA -keysize 2048 -validity 10000
storeFile=../my-upload.keystore
storePassword=CHANGE_ME
keyAlias=my-alias
keyPassword=CHANGE_ME
