# Copy this file to android/keystore.properties and fill in your values.
# NEVER commit keystore.properties or your .keystore file to version control.
# Add both to .gitignore.

# Path to your release keystore file (relative to the android/ directory,
# or an absolute path)
storeFile=../release.keystore

# The password you chose when creating the keystore with keytool
storePassword=YOUR_STORE_PASSWORD

# The alias you chose (e.g. "fluentpath")
keyAlias=fluentpath

# The key password (often the same as storePassword)
keyPassword=YOUR_KEY_PASSWORD
